# ────────── Anthropic (Q&A answering + extraction) ──────────
ANTHROPIC_API_KEY=sk-ant-...

# ────────── OpenAI (embeddings only) ──────────
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ────────── Database (Postgres + pgvector) ──────────
# For Vercel Postgres (Neon): create in Vercel project > Storage > Postgres
# Then copy the connection string from the .env.local tab
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# ────────── Queue (Redis for BullMQ) ──────────
REDIS_URL=redis://localhost:6379

# ────────── App ──────────
# URL of the Fastify API (used by Next.js frontend)
NEXT_PUBLIC_API_URL=http://localhost:3001

NODE_ENV=development
LOG_LEVEL=info
API_PORT=3001
WEB_PORT=3000

UPLOAD_DIR=./data/uploads
DAILY_SPEND_LIMIT_USD=50

# ────────── Support ──────────
# Shown to users when they request a human or we can't answer.
SUPPORT_BUSINESS_HOURS=Monday–Friday, 9:00 AM–6:00 PM ET
