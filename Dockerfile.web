FROM node:20-alpine
WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .

# NEXT_PUBLIC_API_URL must be set at build time — Next.js bakes it in.
# Pass it via: docker-compose build --build-arg NEXT_PUBLIC_API_URL=https://knowledge.lendinggenie.com
ARG NEXT_PUBLIC_API_URL=https://knowledge.lendinggenie.com
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV NODE_ENV=production

RUN node_modules/.bin/next build src/web

EXPOSE 3000
CMD ["node_modules/.bin/next", "start", "src/web", "-p", "3000"]
