# ─────────── Anthropic (Q&A extraction + answering) ───────────
ANTHROPIC_API_KEY=sk-ant-...

# ─────────── OpenAI (embeddings only — text-embedding-3-small) ───────────
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ─────────── Database (Postgres + pgvector) ───────────
DATABASE_URL=postgres://kb:devpassword@localhost:5432/lendinggenie

# ─────────── Queue (Redis for BullMQ) ───────────
REDIS_URL=redis://localhost:6379

# ─────────── Microsoft Teams (user-consent OAuth — no admin needed) ───────────
# Leave blank to skip Teams. See TEAMS_SETUP.md for instructions.
MS_GRAPH_CLIENT_ID=
# Tenant (Directory) ID. Required for single-tenant app registrations
# ("My organization only"). Leave as 'common' only for multi-tenant apps.
MS_GRAPH_TENANT_ID=common
TEAMS_ENG_CHANNEL=

# ─────────── Your company ───────────
# Used to distinguish "our" replies from customer replies in email threads.
INTERNAL_EMAIL_DOMAIN=lendinggenie.com

# ─────────── App ───────────
NODE_ENV=development
LOG_LEVEL=info
API_PORT=3001
WEB_PORT=3000

UPLOAD_DIR=./data/uploads
DAILY_SPEND_LIMIT_USD=50
